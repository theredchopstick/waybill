# Copy this to .env and fill in your values

# Secret used to sign login tokens — change to any long random string
JWT_SECRET=change-me-to-something-long-and-random

# --- Staff notifications ---
# Discord webhook for routine dispatch events (new orders, status changes)
# Server Settings > Integrations > Webhooks > New Webhook > Copy URL
DISCORD_WEBHOOK_DISPATCH=

# Optional second webhook for exceptions/alerts (defaults to dispatch webhook)
DISCORD_WEBHOOK_ALERTS=

# --- Customer notifications ---
# Public channel where player-friendly order updates are posted
# (order received, preparing, out for delivery, delivered, delayed)
DISCORD_WEBHOOK_CUSTOMER=

# Your public site URL — used to build clickable tracking links in
# customer notifications, e.g. https://waybill.onrender.com
PUBLIC_URL=

# PORT=3000
# DB_PATH=./waybill.db
